# Disting NT MCP Server Configuration
# Copy to .env and adjust for your setup

# MIDI port names (substring match, case-insensitive)
# Run list_midi_ports tool to see available ports
DISTING_NT_OUTPUT_PORT=Disting NT
DISTING_NT_INPUT_PORT=Disting NT

# SysEx device ID (0-127, matches module's MIDI channel setting)
DISTING_NT_SYSEX_ID=0

# MIDI channel for standard MIDI messages (1-16)
DISTING_NT_MIDI_CHANNEL=1

# Auto-connect on server start
DISTING_NT_AUTO_CONNECT=true
